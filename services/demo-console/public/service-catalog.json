{
  "version": 1,
  "services": [
    {
      "name": "project-baseline",
      "kind": "project",
      "runtime": "base",
      "port": null,
      "health_url": null,
      "required": true,
      "check": {
        "type": "file",
        "path": "base_manifest.yaml"
      },
      "logs": null
    },
    {
      "name": "postgres",
      "kind": "database",
      "runtime": "compose",
      "port": 5432,
      "health_url": null,
      "required": false,
      "compose_service": "postgres",
      "check": {
        "type": "compose",
        "service": "postgres"
      },
      "logs": "docker compose logs postgres"
    },
    {
      "name": "mysql",
      "kind": "database",
      "runtime": "compose",
      "port": 3306,
      "health_url": null,
      "required": false,
      "compose_service": "mysql",
      "check": {
        "type": "compose",
        "service": "mysql"
      },
      "logs": "docker compose logs mysql"
    },
    {
      "name": "redis",
      "kind": "cache",
      "runtime": "compose",
      "port": 6379,
      "health_url": null,
      "required": false,
      "compose_service": "redis",
      "check": {
        "type": "compose",
        "service": "redis"
      },
      "logs": "docker compose logs redis"
    },
    {
      "name": "go-api",
      "kind": "service",
      "runtime": "docker",
      "port": 8010,
      "health_url": "http://127.0.0.1:8010/healthz",
      "required": false,
      "compose_service": "go-api",
      "check": {
        "type": "http"
      },
      "logs": "docker compose logs go-api"
    },
    {
      "name": "python-api",
      "kind": "service",
      "runtime": "python",
      "port": 8020,
      "health_url": "http://127.0.0.1:8020/healthz",
      "required": false,
      "lifecycle": {
        "type": "process",
        "command": [
          "python3",
          "services/python-api/server.py"
        ]
      },
      "check": {
        "type": "http"
      },
      "logs": "var/services/python-api.log"
    },
    {
      "name": "java-gradle-api",
      "kind": "service",
      "runtime": "java-gradle",
      "port": 8030,
      "health_url": "http://127.0.0.1:8030/healthz",
      "required": false,
      "lifecycle": {
        "type": "process",
        "command": [
          "./services/java-gradle-api/run.sh"
        ]
      },
      "check": {
        "type": "http"
      },
      "logs": "var/services/java-gradle-api.log"
    },
    {
      "name": "java-maven-api",
      "kind": "service",
      "runtime": "java-maven",
      "port": 8040,
      "health_url": "http://127.0.0.1:8040/healthz",
      "required": false,
      "lifecycle": {
        "type": "process",
        "command": [
          "./services/java-maven-api/run.sh"
        ]
      },
      "check": {
        "type": "http"
      },
      "logs": "var/services/java-maven-api.log"
    },
    {
      "name": "c-service",
      "kind": "service",
      "runtime": "native-c",
      "port": 8050,
      "health_url": null,
      "required": false,
      "lifecycle": {
        "type": "process",
        "command": [
          "./services/c-service/run.sh"
        ]
      },
      "check": {
        "type": "command",
        "command": [
          "./services/c-service/build/c-service",
          "--healthz"
        ]
      },
      "logs": "var/services/c-service.log"
    },
    {
      "name": "cpp-service",
      "kind": "service",
      "runtime": "native-cpp",
      "port": 8060,
      "health_url": null,
      "required": false,
      "lifecycle": {
        "type": "process",
        "command": [
          "./services/cpp-service/run.sh"
        ]
      },
      "check": {
        "type": "command",
        "command": [
          "./services/cpp-service/build/cpp-service",
          "--healthz"
        ]
      },
      "logs": "var/services/cpp-service.log"
    },
    {
      "name": "demo-console",
      "kind": "ui",
      "runtime": "react-vite",
      "port": 8070,
      "health_url": "http://127.0.0.1:8070",
      "required": false,
      "lifecycle": {
        "type": "process",
        "command": [
          "./services/demo-console/run.sh"
        ]
      },
      "check": {
        "type": "file",
        "path": "services/demo-console/package.json"
      },
      "logs": "var/services/demo-console.log"
    }
  ]
}
